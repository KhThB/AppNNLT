<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Mobile.ViewModels"
             xmlns:converters="clr-namespace:Mobile.Converters"
             x:Class="Mobile.Views.PoiDetailPage"
             x:DataType="viewmodel:PoiDetailViewModel"
             Title="Thông tin quán ăn"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:DistanceConverter x:Key="DistanceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <!-- ROW 0: Khu vực cuộn chính -->
        <Grid Grid.Row="0">
            <!-- LỚP DƯỚI CÙNG: Ảnh Cover -->
        <Image x:Name="HeaderImage"
               Source="{Binding Poi.ImageUrl}" 
               Aspect="AspectFill"
               HeightRequest="300"
               VerticalOptions="Start"
               BackgroundColor="LightGray" />

        <!-- LỚP TRÊN CÙNG: Nút Back -->
        <Border Margin="15,40,0,0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                HeightRequest="40"
                WidthRequest="40"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                BackgroundColor="#80000000">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked" />
            </Border.GestureRecognizers>
            <Label Text="&#x2190;" TextColor="White" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,0,0,2" />
        </Border>

        <!-- LỚP ĐÈ (BOTTOM SHEET): Phần nội dung nền trắng -->
        <Border Margin="0,270,0,0"
                Padding="20"
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="15" Opacity="0.1" />
            </Border.Shadow>

            <ScrollView x:Name="ContentScroll" Scrolled="ContentScroll_Scrolled" VerticalScrollBarVisibility="Never" Margin="0,0,0,10">
                    <VerticalStackLayout Spacing="15">

                        <Label Text="{Binding Poi.Name}" 
                               FontSize="24" 
                               FontAttributes="Bold" 
                               TextColor="#333333" />

                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📍" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="{Binding Poi.Address}" 
                                   FontSize="16" 
                                   TextColor="#666666" 
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Metadata Tags -->
                        <HorizontalStackLayout Spacing="8">
                            <!-- Khoảng cách -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#FFF0E6" Padding="10,6">
                                <Label Text="{Binding Poi.Distance, Converter={StaticResource DistanceConverter}, StringFormat='📍 Cách {0}'}" 
                                       TextColor="#FF6B35" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                            </Border>

                            <!-- Tag tĩnh 1 -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F3E5F5" Padding="10,6">
                                <Label Text="Ốc" TextColor="#7B1FA2" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                            </Border>

                            <!-- Tag tĩnh 2 -->
                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F3E5F5" Padding="10,6">
                                <Label Text="Ăn đêm" TextColor="#7B1FA2" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5" />

                        <!-- Mini Audio Player: Giới thiệu & Thuyết minh -->
                        <Border StrokeShape="RoundRectangle 25" StrokeThickness="0" BackgroundColor="#F0E6FF" Padding="20,12" Margin="0,5">
                            <Grid ColumnDefinitions="*, Auto">
                                <!-- Bên trái: Tiêu đề và Dropdown ngôn ngữ -->
                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="Thuyết minh" FontSize="16" FontAttributes="Bold" TextColor="#4B0082" VerticalOptions="Center" />
                                        
                                        <!-- Sóng âm nhấp nháy khi đang phát -->
                                        <Label Text="ılı.lıllılı.ıllı" FontSize="12" TextColor="#4B0082" VerticalOptions="Center" IsVisible="{Binding IsSpeaking}" />
                                    </HorizontalStackLayout>
                                    
                                    <!-- Dropdown Language trong suốt -->
                                    <Grid Margin="0,2,0,0">
                                        <Picker ItemsSource="{Binding AvailableLanguages}" 
                                                SelectedItem="{Binding SelectedLanguage}" 
                                                TextColor="Transparent" 
                                                BackgroundColor="Transparent" 
                                                Title="Ngôn ngữ" 
                                                HeightRequest="30" />
                                        
                                        <HorizontalStackLayout Spacing="6" InputTransparent="True" VerticalOptions="Center">
                                            <Label Text="{Binding SelectedLanguage}" FontSize="13" TextColor="#7B1FA2" FontAttributes="Bold" />
                                            <Label Text="▼" FontSize="10" TextColor="#7B1FA2" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Bên phải: Nút Play/Pause Tròn -->
                                <Border Grid.Column="1" 
                                        StrokeShape="RoundRectangle 25" 
                                        StrokeThickness="0" 
                                        HeightRequest="50" 
                                        WidthRequest="50" 
                                        BackgroundColor="#4B0082" 
                                        VerticalOptions="Center">
                                    <Border.Shadow>
                                        <Shadow Brush="#4B0082" Offset="0,4" Radius="8" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SpeakDescriptionCommand}" />
                                    </Border.GestureRecognizers>
                                    <!-- Icon Play/Pause thay đổi theo trạng thái IsSpeaking -->
                                    <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" TextColor="White" FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSpeaking}" Value="False">
                                                <Setter Property="Text" Value="▶" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSpeaking}" Value="True">
                                                <Setter Property="Text" Value="⏸" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Nội dung bài viết mô tả (WordWrap) -->
                        <Label Text="{Binding DisplayDescription}" 
                               FontSize="16" 
                               TextColor="#444444" 
                               LineHeight="1.5"
                               LineBreakMode="WordWrap" />

                    </VerticalStackLayout>
                </ScrollView>
        </Border>
        </Grid> <!-- End of Row 0 -->

        <!-- ROW 1: STICKY BOTTOM BAR -->
        <Border Grid.Row="1" 
                BackgroundColor="White" 
                StrokeThickness="0" 
                Padding="20,15,20,30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="10" Opacity="0.1" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Grid.Column="0"
                        Text="Chỉ đường" 
                        Command="{Binding OpenMapCommand}"
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" 
                        CornerRadius="12"
                        FontAttributes="Bold">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="8" Opacity="0.3" />
                    </Button.Shadow>
                </Button>
                <Button Grid.Column="1" 
                        Command="{Binding ToggleFavoriteCommand}"
                        BorderWidth="2"
                        CornerRadius="12"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="False">
                            <Setter Property="Text" Value="🤍 Yêu thích" />
                            <Setter Property="BackgroundColor" Value="White" />
                            <Setter Property="TextColor" Value="{StaticResource Primary}" />
                            <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="Text" Value="❤️ Đã lưu" />
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="BorderColor" Value="Transparent" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>
    </Grid>
</ContentPage>