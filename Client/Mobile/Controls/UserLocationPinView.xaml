<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mobile.Controls.UserLocationPinView"
             WidthRequest="80" HeightRequest="80">
             
    <!-- Kích thước 80x80 để đảm bảo khi vòng ngoài scale 1.5x (50 * 1.5 = 75) không bị cắt lẹm -->
    <Grid HorizontalOptions="Center" VerticalOptions="Center">
        
        <!-- Lớp ngoài: PulseRing (50x50) -->
        <Border x:Name="pulseRing"
                WidthRequest="50" HeightRequest="50"
                StrokeThickness="0"
                BackgroundColor="#802196F3"
                StrokeShape="RoundRectangle 25"
                HorizontalOptions="Center" VerticalOptions="Center" />

        <!-- Lớp trong: Core (24x24) -->
        <Border WidthRequest="24" HeightRequest="24"
                StrokeThickness="3" Stroke="White"
                BackgroundColor="#2196F3"
                StrokeShape="RoundRectangle 12"
                HorizontalOptions="Center" VerticalOptions="Center">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.3" />
            </Border.Shadow>
        </Border>

    </Grid>
</ContentView>
