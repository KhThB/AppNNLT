@page "/"
@page "/dashboard"
@implements IDisposable
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard Quản Trị</MudText>

@if (stats == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Tổng Doanh Thu</MudText>
                <MudText Typo="Typo.h5" Color="Color.Success">@stats.TotalRevenue.ToString("N0") VNĐ</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Lượt Quét QR</MudText>
                <MudText Typo="Typo.h5">@stats.TotalQRScans</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Lượt Nghe TTS</MudText>
                <MudText Typo="Typo.h5">@stats.TotalTTSPlays</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center">
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Dwell Time (TB)</MudText>
                <MudText Typo="Typo.h5" Color="Color.Info">@stats.AverageDwellTime</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudPaper Elevation="4" Class="pa-4 d-flex flex-column align-center justify-center" Style="background-color: #ffebee;">
                <MudText Typo="Typo.subtitle1" Color="Color.Error" Style="font-weight: bold;">🔴 Đang Trực Tuyến</MudText>
                <MudText Typo="Typo.h4" Color="Color.Error">@_onlineUsers</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-4">
        <MudItem xs="12" md="6">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Lượt quét QR (7 ngày qua)</MudText>
                <MudChart T="double" ChartType="ChartType.Bar"
                          ChartSeries="@Series"
                          XAxisLabels="@stats.ChartLabels"
                          Width="100%" Height="300px" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Mật độ Quán Ăn (Cluster Map)</MudText>
                <div id="heatmap" style="min-height: 300px; width: 100%; border-radius: 8px; border: 1px solid #ccc; z-index: 1;"></div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
@code {
    private DashboardStats? stats;
    public List<ChartSeries<double>> Series = new();
    
    private int _onlineUsers = 0;
    private System.Threading.Timer? _timer;
    
    // CỜ ĐÁNH DẤU BẢN ĐỒ
    private bool _mapInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        stats = await Http.GetFromJsonAsync<DashboardStats>("api/Analytics/dashboard-stats");
        if (stats != null)
        {
            Series.Add(new ChartSeries<double>() { Name = "Lượt quét", Data = stats.ChartData });
        }
        
        _timer = new System.Threading.Timer(async _ =>
        {
            await FetchOnlineCount();
            await InvokeAsync(StateHasChanged);
        }, null, 0, 5000);
    }

    private async Task FetchOnlineCount()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<OnlineStat>("api/Tracking/online-count");
            if (res != null) _onlineUsers = res.ActiveUsers;
        }
        catch { }
    }

    // HÀM NÀY ĐÃ ĐƯỢC SỬA LẠI LOGIC
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Khi stats ĐÃ CÓ DATA (khung div đã xuất hiện) VÀ bản đồ CHƯA ĐƯỢC VẼ
        if (stats != null && !_mapInitialized)
        {
            _mapInitialized = true; // Khóa lại, chỉ vẽ 1 lần duy nhất
            await InitHeatmap();
        }
    }

    private async Task InitHeatmap()
    {
        try
        {
            await Task.Delay(100); // Đợi 1 chút xíu cho DOM ổn định

            bool mapExists = false;
            for (int i = 0; i < 10; i++)
            {
                mapExists = await JS.InvokeAsync<bool>("eval", "document.getElementById('heatmap') != null");
                if (mapExists) break;
                await Task.Delay(200);
            }

            if (mapExists)
            {
                // Lấy danh sách Quán ăn thật từ API để gắn ghim
                var poiResponse = await Http.GetFromJsonAsync<TourGuide.WebAdmin.Components.Pages.POIManagement.PagedResult<TourGuide.Domain.Models.POI>>("api/POI/approved?page=1&limit=1000");
                var points = new List<object>();

                if(poiResponse != null && poiResponse.Data != null)
                {
                    foreach(var poi in poiResponse.Data)
                    {
                        if(poi.Location != null && poi.Location.Coordinates != null && poi.Location.Coordinates.Length == 2)
                        {
                            // Coordinates format is [Lng, Lat], Leaflet expects [Lat, Lng]
                            points.Add(new object[] { poi.Location.Coordinates[1], poi.Location.Coordinates[0], poi.Name });
                        }
                    }
                }

                await JS.InvokeVoidAsync("renderClusterMap", "heatmap", points);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Lỗi tải ClusterMap: " + ex.Message);
        }
    }

    public void Dispose() => _timer?.Dispose();

    public class DashboardStats
    {
        public decimal TotalRevenue { get; set; }
        public int TotalQRScans { get; set; }
        public int TotalTTSPlays { get; set; }
        public string AverageDwellTime { get; set; } = "0s";
        public string[] ChartLabels { get; set; } = [];
        public double[] ChartData { get; set; } = [];
    }
    
    public class OnlineStat { public int ActiveUsers { get; set; } }
}