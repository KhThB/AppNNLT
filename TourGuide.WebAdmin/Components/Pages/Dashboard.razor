@page "/"
@page "/admin/dashboard"
@page "/dashboard"
@rendermode InteractiveServer
@using TourGuide.WebAdmin.Components.Shared
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PortalGuard RequiredRole="Admin" RedirectTo="/admin/login" OnAuthorized="LoadAfterAuthAsync">
    @if (_loading)
    {
        <div class="d-flex justify-center my-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_overview != null)
    {
        <MudText Typo="Typo.h4" GutterBottom="true">Dashboard quan tri</MudText>
        <MudGrid Class="mb-6">
            @foreach (var metric in _overview.Metrics)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
                        <MudText Typo="Typo.caption">@metric.Label</MudText>
                        <MudText Typo="Typo.h4">@metric.Value</MudText>
                    </MudPaper>
                </MudItem>
            }
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
                    <MudText Typo="Typo.caption">MRR</MudText>
                    <MudText Typo="Typo.h4">@_overview.MonthlyRecurringRevenue.ToString("N0") VND</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
                    <MudText Typo="Typo.caption">Total Revenue</MudText>
                    <MudText Typo="Typo.h4">@_overview.TotalRevenue.ToString("N0") VND</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudGrid Class="mb-6">
            <MudItem xs="12" lg="7">
                <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
                    <MudText Typo="Typo.h6" Class="mb-3">QR trend 7 ngay</MudText>
                    @RenderBars(_overview.QrTrend, "#1d4ed8")
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-3">TTS trend 7 ngay</MudText>
                    @RenderBars(_overview.TtsTrend, "#d97706")
                </MudPaper>
            </MudItem>
            <MudItem xs="12" lg="5">
                <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
                    <MudText Typo="Typo.h6" Class="mb-3">Heatmap nguoi dung</MudText>
                    <div id="admin-heatmap" style="height: 360px; min-height: 360px; border-radius: 12px;"></div>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
            <MudText Typo="Typo.h6" Class="mb-3">Recent audit</MudText>
            <MudTable Items="_overview.RecentAuditLogs" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Action</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Target</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Time</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.ActionType</MudTd>
                    <MudTd>@context.ActorRole</MudTd>
                    <MudTd>@context.TargetType / @context.TargetId</MudTd>
                    <MudTd>@context.Description</MudTd>
                    <MudTd>@context.Timestamp.ToLocalTime().ToString("dd/MM HH:mm")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</PortalGuard>

@code {
    private AdminOverview? _overview;
    private List<HeatmapPoint> _heatmap = new();
    private bool _loading = true;
    private bool _mapRendered;

    private async Task LoadAfterAuthAsync(SessionUser user)
    {
        try
        {
            _overview = await Http.GetFromJsonAsync<AdminOverview>("api/analytics/admin/overview");
            _heatmap = await Http.GetFromJsonAsync<List<HeatmapPoint>>("api/analytics/admin/heatmap?hours=4") ?? new();
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Khong tai duoc dashboard quan tri. Vui long dang nhap lai bang tai khoan admin.", Severity.Error);
            _overview = new AdminOverview();
            _heatmap = new();
        }

        _loading = false;
        _mapRendered = false;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_mapRendered)
        {
            _mapRendered = true;
            await JS.InvokeVoidAsync("renderHeatmapMap", "admin-heatmap", _heatmap);
        }
    }

    private RenderFragment RenderBars(IReadOnlyList<TrendPoint> points, string color) => builder =>
    {
        var max = Math.Max(1, points.Count == 0 ? 1 : points.Max(x => x.Value));
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "style", "display:grid; gap:10px;");
        foreach (var point in points)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "style", "display:grid; grid-template-columns:70px 1fr 60px; gap:12px; align-items:center;");
            builder.AddContent(seq++, point.Label);
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "style", "background:#e2e8f0; height:12px; border-radius:999px; overflow:hidden;");
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "style", $"background:{color}; width:{Math.Round(point.Value / max * 100, 2)}%; height:12px;");
            builder.CloseElement();
            builder.CloseElement();
            builder.AddContent(seq++, point.Value.ToString("N0"));
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private sealed class AdminOverview
    {
        public List<Metric> Metrics { get; set; } = new();
        public decimal MonthlyRecurringRevenue { get; set; }
        public decimal TotalRevenue { get; set; }
        public List<TrendPoint> QrTrend { get; set; } = new();
        public List<TrendPoint> TtsTrend { get; set; } = new();
        public List<AuditLogItem> RecentAuditLogs { get; set; } = new();
    }

    private sealed class Metric
    {
        public string Label { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private sealed class TrendPoint
    {
        public string Label { get; set; } = string.Empty;
        public double Value { get; set; }
    }

    private sealed class AuditLogItem
    {
        public string ActionType { get; set; } = string.Empty;
        public string ActorRole { get; set; } = string.Empty;
        public string TargetType { get; set; } = string.Empty;
        public string TargetId { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }

    private sealed class HeatmapPoint
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public int Intensity { get; set; }
    }
}
