@page "/merchant"
@layout TourGuide.WebAdmin.Components.Layout.MerchantLayout
@rendermode InteractiveServer
@using MudBlazor
@using TourGuide.Domain.Models
@using System.Net.Http.Headers
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-16">
    
    @* ================= TRẠNG THÁI 1: YÊU CẦU ĐĂNG NHẬP ================= *@
    @if (string.IsNullOrEmpty(_currentMerchantId))
    {
        <MudGrid Justify="Justify.Center">
            <MudItem xs="12" sm="6" md="5">
                <MudPaper Elevation="3" Class="pa-8">
                    <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Dành Cho Chủ Quán</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-6">Đăng nhập để quản lý quán ăn của bạn trên hệ thống VinhKhanhFoodTour.</MudText>
                    
                    <MudTextField @bind-Value="_loginPhone" Label="Số điện thoại" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_loginPassword" Label="Mật khẩu" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-6" />
                    
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" OnClick="RealLogin">Đăng Nhập</MudButton>
                    <div class="d-flex justify-center mt-4">
                        <MudLink Href="#">Chưa có tài khoản? Đăng ký ngay</MudLink>
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    
    @* ================= TRẠNG THÁI 2: CHƯA CÓ QUÁN -> TẠO QUÁN ================= *@
    else if (_myPoi == null)
    {
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Đưa Quán Của Bạn Lên Bản Đồ</MudText>
        <MudPaper Elevation="3" Class="pa-8 mt-6 mx-auto" Style="max-width: 800px;">
            <MudTextField @bind-Value="_newPoi.Name" Label="Tên Quán Ăn" Variant="Variant.Outlined" Class="mb-4" />
            <MudTextField @bind-Value="_newPoi.MerchantNote" Label="Giới thiệu & Thuyết minh" Lines="4" Variant="Variant.Outlined" Class="mb-6" />
            
            <MudText Typo="Typo.h6" Class="mb-2">Chọn vị trí (Bản đồ)</MudText>
            <div id="merchant-map" style="height: 300px; width: 100%; border-radius: 8px; border: 1px solid #ccc; z-index: 1;" class="mb-6"></div>

            <MudText Typo="Typo.h6" Class="mb-4">Chọn gói dịch vụ</MudText>
            <MudSelect T="string" @bind-Value="_selectedPackage" Label="Gói đăng ký" Variant="Variant.Outlined" Class="mb-6">
                <MudSelectItem Value="@("Basic")">Gói Cơ Bản (Miễn Phí) - Chỉ Tiếng Việt</MudSelectItem>
                <MudSelectItem Value="@("Premium")">Gói Premium (150.000đ/tháng) - Dịch AI 4 ngôn ngữ + Nổi bật</MudSelectItem>
            </MudSelect>

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" OnClick="SubmitAndPay">
                @(_selectedPackage == "Basic" ? "Gửi Yêu Cầu Duyệt" : "Thanh Toán & Đăng Ký (150k)")
            </MudButton>
        </MudPaper>
    }

    @* ================= TRẠNG THÁI 3: ĐÃ CÓ QUÁN -> DASHBOARD CHỦ QUÁN ================= *@
    else
    {
        <div class="d-flex justify-space-between align-center mb-6">
            <div>
                <MudText Typo="Typo.h4">Xin chào, @_myPoi.Name!</MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    Trạng thái:
                    <MudChip T="string" Color="@(_myPoi.Status == "Approved" ? Color.Success : Color.Warning)" Size="Size.Small">@_myPoi.Status</MudChip>
                </MudText>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="Logout">Đăng Xuất</MudButton>
        </div>

        <MudGrid>
            @* Thống kê nhanh *@
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.QrCodeScanner" Color="Color.Primary" Style="font-size: 3rem;" />
                    <MudText Typo="Typo.h4" Class="mt-2">@_myPoi.QRScanCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Lượt khách quét mã</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.VolumeUp" Color="Color.Secondary" Style="font-size: 3rem;" />
                    <MudText Typo="Typo.h4" Class="mt-2">@_myPoi.TTSPlayCount</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Lượt nghe thuyết minh</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Warning" Style="font-size: 3rem;" />
                    <MudText Typo="Typo.h5" Class="mt-2">@_myPoi.SubscriptionPackage</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Gói dịch vụ hiện tại</MudText>
                </MudPaper>
            </MudItem>

            @* Sửa tên & Thuyết minh *@
            <MudItem xs="12" md="6">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.h6">Thông tin & Thuyết minh</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="_myPoi.Name" Label="Tên Quán Ăn" Variant="Variant.Outlined" Class="mb-4" />
                        <MudTextField @bind-Value="_myPoi.Description_VI" Label="Thuyết minh (Tiếng Việt)" Lines="5" Variant="Variant.Outlined" />
                        <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-2 d-block">
                            *Nội dung này sẽ hiển thị cho khách quét QR.
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UpdateMerchantPoi" StartIcon="@Icons.Material.Filled.Save">Lưu Thay Đổi</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            @* Bản đồ vị trí hiện tại *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4" Style="height: 100%; min-height: 380px;">
                    <MudText Typo="Typo.h6" Class="mb-2">Vị trí quán trên bản đồ</MudText>
                    <div id="merchant-view-map" style="height: 300px; width: 100%; border-radius: 8px; border: 1px solid #ccc; z-index: 1;"></div>
                </MudPaper>
            </MudItem>

            @* Hình ảnh *@
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent><MudText Typo="Typo.h6">Hình ảnh đại diện</MudText></CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" sm="4">
                                @if (!string.IsNullOrEmpty(_myPoi.ImageUrl))
                                {
                                    <img src="@(_myPoi.ImageUrl.StartsWith("http") ? _myPoi.ImageUrl : $"{Http.BaseAddress}{_myPoi.ImageUrl.TrimStart('/')}")"
                                         style="width: 100%; max-height: 200px; object-fit: cover; border-radius: 8px;" />
                                }
                            </MudItem>
                            <MudItem xs="12" sm="8" Class="d-flex align-center">
                                <InputFile id="merchantImage" OnChange="UploadMerchantImage" hidden accept=".jpg,.jpeg,.png" />
                                <MudButton HtmlTag="label" for="merchantImage" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                                    Thay Đổi Ảnh Quán
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private string? _currentMerchantId = null;
    private POI? _myPoi = null;

    private string _loginPhone = "";
    private string _loginPassword = "";

    private POI _newPoi = new POI();
    private string _selectedPackage = "Basic";
    private double _lat = 10.7628;
    private double _lng = 106.7005;

    private bool _mapInitialized = false;
    private bool _viewMapInitialized = false; // Cờ cho bản đồ Dashboard

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await LocalStorage.GetItemAsync<string>("authToken");
            var merchantId = await LocalStorage.GetItemAsync<string>("merchantId");
            if (string.IsNullOrEmpty(merchantId))
                merchantId = await LocalStorage.GetItemAsync<string>("merchantid");

            if (!string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(merchantId))
            {
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
                _currentMerchantId = merchantId;
                await CheckExistingPoi();
            }
            StateHasChanged();
        }

        // Bản đồ trạng thái 2 (Tạo quán)
        if (!string.IsNullOrEmpty(_currentMerchantId) && _myPoi == null && !_mapInitialized)
        {
            _mapInitialized = true;
            await InitMap();
        }

        // Bản đồ trạng thái 3 (Dashboard - Xem quán)
        if (_myPoi != null && !_viewMapInitialized)
        {
            _viewMapInitialized = true;
            await InitViewMap();
        }
    }

    private async Task RealLogin()
    {
        try
        {
            var loginData = new { Phone = _loginPhone, Password = _loginPassword };
            var response = await Http.PostAsJsonAsync("api/Auth/login", loginData);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResult>();
                if (result != null && result.User != null)
                {
                    await LocalStorage.SetItemAsync("merchantId", result.User.Id);
                    await LocalStorage.SetItemAsync("authToken", result.Token);
                    
                    Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", result.Token);
                    _currentMerchantId = result.User.Id;
                    Snackbar.Add("Đăng nhập thành công!", Severity.Success);
                    await CheckExistingPoi();
                }
            }
            else
            {
                Snackbar.Add($"Sai tài khoản hoặc mật khẩu!", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi kết nối: {ex.Message}", Severity.Warning);
        }
    }

    private async Task CheckExistingPoi()
    {
        try
        {
            var response = await Http.GetAsync($"api/POI/merchant/{_currentMerchantId}");
            if (response.IsSuccessStatusCode)
            {
                var myPois = await response.Content.ReadFromJsonAsync<List<POI>>();
                _myPoi = myPois?.FirstOrDefault();
                _viewMapInitialized = false; // Để nó vẽ lại bản đồ Dashboard khi login
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi: {ex.Message}");
        }
    }

    private async Task InitMap()
    {
        try
        {
            await Task.Delay(200);
            var objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initMapPicker", "merchant-map", objRef);
        }
        catch { }
    }

    private async Task InitViewMap()
    {
        try
        {
            await Task.Delay(500); // Chờ MudBlazor vẽ xong khung
            if (_myPoi?.Location?.Coordinates != null)
            {
                // Gọi hàm hiển thị bản đồ tĩnh
                await JS.InvokeVoidAsync("initStaticMap", "merchant-view-map", _myPoi.Location.Coordinates[1], _myPoi.Location.Coordinates[0], _myPoi.Name);
            }
        }
        catch { }
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        await LocalStorage.RemoveItemAsync("merchantId");
        Http.DefaultRequestHeaders.Authorization = null;
        _currentMerchantId = null;
        _myPoi = null;
        _mapInitialized = false;
        _viewMapInitialized = false;
    }

    [JSInvokable]
    public void UpdateCoordinates(double newLat, double newLng)
    {
        _lat = newLat;
        _lng = newLng;
    }

    private async Task SubmitAndPay()
    {
        try
        {
            _newPoi.Id = Guid.NewGuid().ToString("N").Substring(0, 24);
            _newPoi.OwnerId = _currentMerchantId!;
            _newPoi.Location = new GeoLocation { Type = "Point", Coordinates = new double[] { _lng, _lat } };
            _newPoi.SubscriptionPackage = _selectedPackage;
            _newPoi.Description_VI = _newPoi.MerchantNote;

            var response = await Http.PostAsJsonAsync("api/POI", _newPoi);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Gửi yêu cầu thành công!", Severity.Success);
                _myPoi = _newPoi;
                _myPoi.Status = "Pending";
                _viewMapInitialized = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task UpdateMerchantPoi()
    {
        if (_myPoi != null)
        {
            var response = await Http.PutAsJsonAsync($"api/POI/{_myPoi.Id}", _myPoi);
            if (response.IsSuccessStatusCode)
                Snackbar.Add("Đã lưu nội dung!", Severity.Success);
            else
                Snackbar.Add("Lỗi khi lưu!", Severity.Error);
        }
    }

    private async Task UploadMerchantImage(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null || _myPoi == null) return;
        using var content = new MultipartFormDataContent();
        using var stream = file.OpenReadStream(1024 * 1024 * 5);
        using var streamContent = new StreamContent(stream);
        streamContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
        content.Add(streamContent, "file", file.Name);

        var response = await Http.PostAsync("api/POI/upload-image", content);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<UploadResult>();
            if (result != null)
            {
                _myPoi.ImageUrl = result.ImageUrl;
                await Http.PutAsJsonAsync($"api/POI/{_myPoi.Id}", _myPoi);
                Snackbar.Add("Đã cập nhật ảnh!", Severity.Success);
            }
        }
    }

    public class LoginResult { public string Token { get; set; } = ""; public UserDto User { get; set; } = new(); }
    public class UserDto { public string Id { get; set; } = ""; public string Role { get; set; } = ""; }
    private class UploadResult { public string ImageUrl { get; set; } = ""; }
}