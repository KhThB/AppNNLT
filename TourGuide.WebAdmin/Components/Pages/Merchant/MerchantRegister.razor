@page "/merchant/register"
@layout TourGuide.WebAdmin.Components.Layout.MerchantLayout
@rendermode InteractiveServer
@using TourGuide.WebAdmin.Components.Shared
@inject HttpClient Http
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PortalGuard RequiredRole="Merchant" RedirectTo="/merchant/login">
    <MudContainer MaxWidth="MaxWidth.Large" Class="my-8">
        <MudText Typo="Typo.h4" Class="mb-2">Tạo POI mới</MudText>
        <MudText Typo="Typo.body2" Class="mb-6">Mỗi owner có thể tạo nhiều POI, sau đó submit lên admin để duyệt.</MudText>

        <MudPaper Class="pa-6 glass-panel" Style="border-radius: 16px;">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name" Label="Tên quán" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_model.Address" Label="Địa chỉ" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_model.SourceDescription" Label="Nội dung nguồn" Variant="Variant.Outlined" Lines="8" Class="mb-4" />
                    <MudSelect T="string" @bind-Value="_model.SubscriptionPackage" Label="Gói dịch vụ" Variant="Variant.Outlined" Class="mb-4">
                        <MudSelectItem Value="@("Basic")">Basic</MudSelectItem>
                        <MudSelectItem Value="@("Premium")">Premium</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Chọn vị trí POI</MudText>
                    <div id="merchant-map" style="height: 360px; width: 100%; border-radius: 12px; border: 1px solid #cbd5e1;"></div>
                    <MudSlider @bind-Value="_model.Radius" Min="10" Max="500" Step="10" Color="Color.Primary" Class="mt-4">Radius: @_model.Radius m</MudSlider>
                </MudItem>
            </MudGrid>

            <div class="d-flex gap-3 mt-6">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync">Tạo draft</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/merchant/pois">Quay lại quản lý POI</MudButton>
            </div>
        </MudPaper>
    </MudContainer>
</PortalGuard>

@code {
    private CreatePoiModel _model = new();

    private bool _mapInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_mapInitialized)
        {
            var isMapReady = await JS.InvokeAsync<bool>("eval", "document.getElementById('merchant-map') != null");
            if (isMapReady)
            {
                _mapInitialized = true;
                await Task.Delay(50);
                var objRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("initMapPicker", "merchant-map", objRef);
            }
        }
    }

    [JSInvokable]
    public void UpdateCoordinates(double newLat, double newLng)
    {
        _model.Latitude = newLat;
        _model.Longitude = newLng;
    }

    private async Task CreateAsync()
    {
        var response = await Http.PostAsJsonAsync("api/poi", new
        {
            _model.Name,
            _model.Address,
            SourceLanguage = "vi",
            SourceDescription = _model.SourceDescription,
            MerchantNote = _model.SourceDescription,
            _model.Latitude,
            _model.Longitude,
            _model.Radius,
            _model.SubscriptionPackage,
        });

        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add("Tạo POI thất bại.", Severity.Error);
            return;
        }

        Snackbar.Add("Đã tạo draft POI.", Severity.Success);
        Navigation.NavigateTo("/merchant/pois", true);
    }

    private sealed class CreatePoiModel
    {
        public string Name { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string SourceDescription { get; set; } = string.Empty;
        public double Latitude { get; set; } = 10.7628;
        public double Longitude { get; set; } = 106.7005;
        public double Radius { get; set; } = 50;
        public string SubscriptionPackage { get; set; } = "Basic";
    }
}
