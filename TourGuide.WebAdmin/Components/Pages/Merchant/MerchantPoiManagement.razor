@page "/merchant/pois"
@layout TourGuide.WebAdmin.Components.Layout.MerchantLayout
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.JSInterop
@using TourGuide.WebAdmin.Components.Shared
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PortalGuard RequiredRole="Merchant" RedirectTo="/merchant/login" OnAuthorized="LoadAfterAuthAsync">
    <div class="d-flex justify-space-between align-center mb-6">
        <div>
            <MudText Typo="Typo.h4">Quản lý POI của owner</MudText>
            <MudText Typo="Typo.body2">Sửa nội dung nguồn, vị trí, radius và gửi POI lên admin duyệt.</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/merchant/register">Tạo POI</MudButton>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center my-12">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudPaper Class="pa-4 glass-panel" Style="border-radius: 14px;">
            @if (_pois.Count == 0)
            {
                <MudAlert Severity="Severity.Info">Owner này chưa có POI nào. Hãy tạo POI đầu tiên.</MudAlert>
            }
            else
            {
                <MudTable Items="_pois" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Tên quán</MudTh>
                        <MudTh>Tag</MudTh>
                        <MudTh>Trạng thái</MudTh>
                        <MudTh>Gói</MudTh>
                        <MudTh>QR/TTS</MudTh>
                        <MudTh>Hành động</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Name</MudTd>
                        <MudTd>
                            @if (context.Tags.Count == 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Tự suy luận</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">@string.Join(", ", context.Tags)</MudText>
                            }
                        </MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip></MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@(context.SubscriptionPackage == "Premium" ? Color.Warning : Color.Default)">
                                @context.SubscriptionPackage
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.CountedQrScanCount / @context.CountedTtsPlayCount</MudTd>
                        <MudTd>
                            <div class="d-flex gap-2">
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" OnClick="() => SelectPoi(context)">Sửa</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" OnClick="() => SubmitAsync(context.Id)">Gửi duyệt</MudButton>
                            </div>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        @if (_selected != null)
        {
            <MudPaper Class="pa-6 mt-6 glass-panel" Style="border-radius: 14px;">
                <MudText Typo="Typo.h6" Class="mb-4">Cập nhật POI</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_selected.Name" Label="Tên quán" Variant="Variant.Outlined" Class="mb-4" />
                        <MudTextField @bind-Value="_selected.Address" Label="Địa chỉ" Variant="Variant.Outlined" Class="mb-4" />
                        <MudTextField @bind-Value="_selected.TagText" Label="Tag quán" HelperText="Nhập cách nhau bằng dấu phẩy, ví dụ: ốc đêm, ăn vặt, trà sữa" Variant="Variant.Outlined" Class="mb-4" />
                        <MudTextField T="string" Value="_selected.SourceDescription" ValueChanged="OnSelectedSourceDescriptionChangedAsync" Label="Nội dung nguồn" Variant="Variant.Outlined" Lines="6" Immediate="true" />
                        <MudPaper Class="pa-3 mb-4" Outlined="true">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <div>
                                    <MudText Typo="Typo.subtitle2">Ảnh quán</MudText>
                                    <MudText Typo="Typo.caption">Dán URL ảnh hoặc chọn file để upload lên storage.</MudText>
                                </div>
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Disabled="@string.IsNullOrWhiteSpace(_selected.ImageUrl)" OnClick="ClearSelectedImage">
                                    Xóa ảnh
                                </MudButton>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_selected.ImageUrl))
                            {
                                <img src="@_selected.ImageUrl" alt="@_selected.Name" style="width:100%; max-height:220px; object-fit:cover; border-radius:12px; border:1px solid #fed7aa; margin-bottom:12px;" />
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">POI này chưa có ảnh đại diện.</MudAlert>
                            }
                            <MudTextField @bind-Value="_selected.ImageUrl" Label="URL ảnh" Variant="Variant.Outlined" Class="mb-3" Immediate="true" />
                            <InputFile OnChange="UploadSelectedImageAsync" accept="image/*" />
                            @if (_imageUploading)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
                            }
                        </MudPaper>
                        <MudPaper Class="pa-3 my-4" Outlined="true">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <div>
                                    <MudText Typo="Typo.subtitle2">Bản dịch sẽ lưu cùng POI</MudText>
                                    <MudText Typo="Typo.caption">Tự dịch khi nội dung nguồn thay đổi. Có thể chỉnh tay từng ngôn ngữ trước khi lưu.</MudText>
                                </div>
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Disabled="_translationLoading" OnClick="() => PreviewSelectedTranslationsAsync(true)">
                                    Dịch ngay
                                </MudButton>
                            </div>
                            @if (_translationLoading)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                            }
                            @if (!string.IsNullOrWhiteSpace(_translationMessage))
                            {
                                <MudAlert Severity="@GetTranslationAlertSeverity(_selected)" Dense="true" Class="mb-3">
                                    @_translationMessage
                                </MudAlert>
                            }
                            @foreach (var language in TranslationLanguages)
                            {
                                var code = language.Code;
                                <MudTextField T="string"
                                              Value="@GetTranslation(_selected, code)"
                                              ValueChanged="@(value => SetTranslation(_selected, code, value))"
                                              Label="@($"{language.Label} ({code})")"
                                              HelperText="@GetTranslationHelper(_selected, code)"
                                              Variant="Variant.Outlined"
                                              Lines="3"
                                              Class="mb-3" />
                            }
                        </MudPaper>

                        <MudPaper Class="pa-3 mb-4" Outlined="true">
                            <MudText Typo="Typo.caption">Gói hiện tại</MudText>
                            <div class="d-flex justify-space-between align-center mt-1">
                                <MudChip T="string" Color="@(_selected.SubscriptionPackage == "Premium" ? Color.Warning : Color.Default)" Size="Size.Small">
                                    @_selected.SubscriptionPackage
                                </MudChip>
                                <div class="d-flex gap-2">
                                    @if (_selected.SubscriptionPackage != "Premium")
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Warning" Size="Size.Small" OnClick="@(() => StartPackageCheckoutAsync("Premium"))">
                                            Mua Premium
                                        </MudButton>
                                    }
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" OnClick="@(() => StartPackageCheckoutAsync("Boost"))">
                                        Mua Boost
                                    </MudButton>
                                </div>
                            </div>
                            <MudText Typo="Typo.caption" Class="mt-2 d-block">
                                Radius được hệ thống tự áp dụng theo gói: Basic 50m, Premium 120m, Boost 200m khi còn hạn.
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Vị trí và vùng ảnh hưởng</MudText>
                        <div id="@LocationMapId" style="height: 330px; width: 100%; border-radius: 12px; border: 1px solid #cbd5e1;"></div>
                        <MudText Typo="Typo.caption" Class="mt-2 d-block">
                            Kéo marker hoặc click lên bản đồ để đổi vị trí. Vòng tròn là radius geofence của POI.
                        </MudText>
                        <MudGrid Class="mt-3">
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Value="_selected.Latitude" ValueChanged="OnLatitudeChangedAsync" Label="Latitude" Variant="Variant.Outlined" Class="mb-3" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Value="_selected.Longitude" ValueChanged="OnLongitudeChangedAsync" Label="Longitude" Variant="Variant.Outlined" Class="mb-3" />
                            </MudItem>
                        </MudGrid>
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                            Radius hiện tại: @_selected.Radius.ToString("N0") m. Giá trị này do hệ thống tính theo gói, không chỉnh tay.
                        </MudAlert>
                    </MudItem>
                </MudGrid>

                <div class="d-flex gap-3 mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">Lưu</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="() => SubmitAsync(_selected.Id)">Gửi duyệt</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ArchiveSelectedAsync">Xóa / ngưng dịch vụ</MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ClearSelection">Đóng</MudButton>
                </div>
            </MudPaper>
        }
    }
</PortalGuard>

@code {
    private const string LocationMapId = "merchant-poi-location-map";
    private List<PoiRow> _pois = new();
    private PoiRow? _selected;
    private bool _loading = true;
    private bool _locationMapPending;
    private bool _translationLoading;
    private bool _imageUploading;
    private string _translationMessage = string.Empty;
    private CancellationTokenSource? _translationDebounceCts;
    private string _ownerId = "me";
    private DotNetObjectReference<MerchantPoiManagement>? _mapRef;
    private static readonly TranslationLanguage[] TranslationLanguages =
    [
        new("EN", "English"),
        new("KO", "Korean"),
        new("JA", "Japanese"),
        new("ZH", "Chinese"),
    ];

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            _pois = await Http.GetFromJsonAsync<List<PoiRow>>($"api/poi/owner/{_ownerId}") ?? new();
        }
        catch (HttpRequestException)
        {
            Snackbar.Add("Không tải được danh sách POI của owner. Vui lòng đăng nhập lại hoặc thử lại sau.", Severity.Error);
            _pois = new();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadAfterAuthAsync(SessionUser user)
    {
        _ownerId = string.IsNullOrWhiteSpace(user.Id) ? "me" : user.Id;
        await ReloadAsync();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_locationMapPending && _selected != null)
        {
            _locationMapPending = false;
            _mapRef?.Dispose();
            _mapRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initPoiLocationEditor", LocationMapId, _selected.Latitude, _selected.Longitude, _selected.Radius, _mapRef);
        }
    }

    private void SelectPoi(PoiRow row)
    {
        _selected = new PoiRow
        {
            Id = row.Id,
            Name = row.Name,
            Address = row.Address,
            Tags = row.Tags.ToList(),
            TagText = string.Join(", ", row.Tags),
            SourceDescription = row.SourceDescription,
            TranslatedDescriptions = new Dictionary<string, string>(row.TranslatedDescriptions, StringComparer.OrdinalIgnoreCase),
            TranslationStatuses = BuildReadyStatuses(row.TranslatedDescriptions),
            Latitude = row.Latitude,
            Longitude = row.Longitude,
            Radius = row.Radius <= 0 ? 50 : row.Radius,
            PriorityLevel = row.PriorityLevel,
            BoostPriority = row.BoostPriority,
            SubscriptionPackage = row.SubscriptionPackage,
            ImageUrl = row.ImageUrl,
        };
        _translationMessage = _selected.TranslatedDescriptions.Count > 0
            ? "Đã tải bản dịch hiện có. Sửa nội dung nguồn sẽ tự dịch lại."
            : "Chưa có bản dịch. Nhập nội dung nguồn hoặc bấm Dịch ngay.";
        _locationMapPending = true;
    }

    [JSInvokable]
    public void UpdateLocationFromMap(double latitude, double longitude)
    {
        if (_selected == null)
        {
            return;
        }

        _selected.Latitude = Math.Round(latitude, 6);
        _selected.Longitude = Math.Round(longitude, 6);
        StateHasChanged();
    }

    private async Task OnLatitudeChangedAsync(double value)
    {
        if (_selected == null) return;
        _selected.Latitude = value;
        await JS.InvokeVoidAsync("updatePoiLocationPosition", LocationMapId, _selected.Latitude, _selected.Longitude);
    }

    private async Task OnLongitudeChangedAsync(double value)
    {
        if (_selected == null) return;
        _selected.Longitude = value;
        await JS.InvokeVoidAsync("updatePoiLocationPosition", LocationMapId, _selected.Latitude, _selected.Longitude);
    }

    private void ClearSelection()
    {
        _selected = null;
    }

    private async Task SaveAsync()
    {
        if (_selected == null)
        {
            return;
        }

        if (!HasReadyTranslations(_selected))
        {
            await PreviewSelectedTranslationsAsync(false);
        }

        var response = await Http.PutAsJsonAsync($"api/poi/{_selected.Id}", new
        {
            _selected.Name,
            _selected.Address,
            Tags = ParseTags(_selected.TagText),
            SourceLanguage = "vi",
            SourceDescription = _selected.SourceDescription,
            TranslatedDescriptions = BuildReadyTranslations(_selected),
            MerchantNote = _selected.SourceDescription,
            _selected.Latitude,
            _selected.Longitude,
            _selected.PriorityLevel,
            _selected.BoostPriority,
            _selected.SubscriptionPackage,
            _selected.ImageUrl,
        });

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã lưu POI.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Không thể lưu POI.", Severity.Error);
    }

    private async Task UploadSelectedImageAsync(InputFileChangeEventArgs args)
    {
        if (_selected == null)
        {
            return;
        }

        var file = args.File;
        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Vui lòng chọn file ảnh hợp lệ.", Severity.Warning);
            return;
        }

        _imageUploading = true;
        try
        {
            using var form = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            form.Add(fileContent, "file", file.Name);

            var response = await Http.PostAsync("api/poi/upload-image", form);
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add("Upload ảnh thất bại. Có thể storage chưa được cấu hình, bạn vẫn có thể dán URL ảnh.", Severity.Error);
                return;
            }

            var upload = await response.Content.ReadFromJsonAsync<ImageUploadResponse>();
            if (upload == null || string.IsNullOrWhiteSpace(upload.ImageUrl))
            {
                Snackbar.Add("Upload ảnh không trả về URL hợp lệ.", Severity.Error);
                return;
            }

            _selected.ImageUrl = upload.ImageUrl;
            Snackbar.Add("Đã upload ảnh, bấm Lưu để cập nhật POI.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload ảnh thất bại: {ex.Message}", Severity.Error);
        }
        finally
        {
            _imageUploading = false;
        }
    }

    private void ClearSelectedImage()
    {
        if (_selected == null)
        {
            return;
        }

        _selected.ImageUrl = string.Empty;
    }

    private Task OnSelectedSourceDescriptionChangedAsync(string value)
    {
        if (_selected == null)
        {
            return Task.CompletedTask;
        }

        _selected.SourceDescription = value;
        QueueTranslationPreview();
        return Task.CompletedTask;
    }

    private void QueueTranslationPreview()
    {
        _translationDebounceCts?.Cancel();
        _translationDebounceCts?.Dispose();

        if (_selected == null || string.IsNullOrWhiteSpace(_selected.SourceDescription))
        {
            if (_selected != null)
            {
                _selected.TranslatedDescriptions.Clear();
                _selected.TranslationStatuses.Clear();
                _selected.TranslationErrors.Clear();
            }

            _translationMessage = string.Empty;
            return;
        }

        foreach (var language in TranslationLanguages)
        {
            _selected.TranslatedDescriptions[language.Code] = string.Empty;
            _selected.TranslationStatuses[language.Code] = "PendingManual";
            _selected.TranslationErrors.Remove(language.Code);
        }

        var cts = new CancellationTokenSource();
        _translationDebounceCts = cts;
        _ = DebouncedPreviewAsync(cts.Token);
    }

    private async Task DebouncedPreviewAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(900, cancellationToken);
            await InvokeAsync(() => PreviewSelectedTranslationsAsync(false));
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task PreviewSelectedTranslationsAsync(bool showSnackbar)
    {
        if (_selected == null)
        {
            return;
        }

        var sourceText = (_selected.SourceDescription ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(sourceText))
        {
            _selected.TranslatedDescriptions.Clear();
            _selected.TranslationStatuses.Clear();
            _selected.TranslationErrors.Clear();
            _translationMessage = string.Empty;
            return;
        }

        _translationLoading = true;
        _translationMessage = "Đang dịch nội dung nguồn...";
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/translation/preview", new TranslationPreviewRequestModel
            {
                SourceLanguage = "vi",
                SourceDescription = sourceText,
                TargetLanguages = TranslationLanguages.Select(x => x.Code).ToArray(),
            });

            if (!response.IsSuccessStatusCode)
            {
                _translationMessage = "Không gọi được API dịch. Bạn vẫn có thể nhập bản dịch thủ công.";
                if (showSnackbar)
                {
                    Snackbar.Add(_translationMessage, Severity.Warning);
                }

                return;
            }

            var preview = await response.Content.ReadFromJsonAsync<TranslationPreviewResponseModel>();
            if (preview == null)
            {
                _translationMessage = "API dịch không trả về dữ liệu hợp lệ.";
                return;
            }

            foreach (var language in TranslationLanguages)
            {
                if (!preview.Contents.TryGetValue(language.Code, out var content))
                {
                    continue;
                }

                _selected.TranslationStatuses[language.Code] = content.Status;
                _selected.TranslationErrors[language.Code] = content.ErrorMessage;
                if (content.Status == "Ready")
                {
                    _selected.TranslatedDescriptions[language.Code] = content.Description;
                }
                else if (!_selected.TranslatedDescriptions.ContainsKey(language.Code))
                {
                    _selected.TranslatedDescriptions[language.Code] = string.Empty;
                }
            }

            _translationMessage = preview.IsProviderConfigured
                ? "Bản dịch đã sẵn sàng và sẽ được lưu cùng POI."
                : "Google Cloud Translation chưa được cấu hình. Nhập tay bản dịch hoặc cấu hình API key.";

            if (showSnackbar)
            {
                Snackbar.Add(_translationMessage, preview.IsProviderConfigured ? Severity.Success : Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _translationMessage = $"Lỗi dịch: {ex.Message}";
            if (showSnackbar)
            {
                Snackbar.Add(_translationMessage, Severity.Error);
            }
        }
        finally
        {
            _translationLoading = false;
            StateHasChanged();
        }
    }

    private static string GetTranslation(PoiRow? model, string language)
    {
        return model?.TranslatedDescriptions.TryGetValue(language, out var text) == true ? text : string.Empty;
    }

    private static void SetTranslation(PoiRow? model, string language, string value)
    {
        if (model == null)
        {
            return;
        }

        model.TranslatedDescriptions[language] = value;
        model.TranslationStatuses[language] = string.IsNullOrWhiteSpace(value) ? "PendingManual" : "Ready";
        model.TranslationErrors.Remove(language);
    }

    private static string GetTranslationHelper(PoiRow? model, string language)
    {
        if (model == null)
        {
            return string.Empty;
        }

        var status = model.TranslationStatuses.TryGetValue(language, out var value) ? value : "PendingManual";
        if (status == "Ready")
        {
            return "Sẵn sàng lưu xuống DB.";
        }

        return model.TranslationErrors.TryGetValue(language, out var error) && !string.IsNullOrWhiteSpace(error)
            ? error
            : "Chưa có bản dịch. Có thể nhập tay.";
    }

    private static Dictionary<string, string> BuildReadyTranslations(PoiRow model)
    {
        return TranslationLanguages
            .Where(x => model.TranslationStatuses.TryGetValue(x.Code, out var status) && status == "Ready")
            .Select(x => new { x.Code, Text = GetTranslation(model, x.Code).Trim() })
            .Where(x => !string.IsNullOrWhiteSpace(x.Text))
            .ToDictionary(x => x.Code, x => x.Text, StringComparer.OrdinalIgnoreCase);
    }

    private static bool HasReadyTranslations(PoiRow model)
    {
        return BuildReadyTranslations(model).Count > 0;
    }

    private static Severity GetTranslationAlertSeverity(PoiRow model)
    {
        return model.TranslationStatuses.Values.Any(x => x == "PendingManual")
            ? Severity.Warning
            : Severity.Success;
    }

    private static Dictionary<string, string> BuildReadyStatuses(IReadOnlyDictionary<string, string> translations)
    {
        return translations
            .Where(x => !string.IsNullOrWhiteSpace(x.Value))
            .ToDictionary(x => x.Key, _ => "Ready", StringComparer.OrdinalIgnoreCase);
    }

    private async Task StartPackageCheckoutAsync(string packageName)
    {
        if (_selected == null)
        {
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/billing/package/checkout", new { PoiId = _selected.Id, PackageName = packageName });
            if (!response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Không tạo được link thanh toán {packageName}. Hãy kiểm tra cấu hình PayOS.", Severity.Error);
                return;
            }

            var checkout = await response.Content.ReadFromJsonAsync<PremiumCheckoutResponse>();
            if (checkout == null || string.IsNullOrWhiteSpace(checkout.CheckoutUrl))
            {
                Snackbar.Add("PayOS không trả về checkout URL.", Severity.Error);
                return;
            }

            Snackbar.Add($"Đã tạo link thanh toán {packageName}.", Severity.Success);
            await JS.InvokeVoidAsync("open", checkout.CheckoutUrl, "_blank");
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task SubmitAsync(string id)
    {
        var response = await Http.PostAsync($"api/poi/{id}/submit", null);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã gửi POI lên duyệt.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Gửi duyệt thất bại.", Severity.Error);
    }

    private async Task ArchiveSelectedAsync()
    {
        if (_selected == null) return;
        var response = await Http.DeleteAsync($"api/poi/{_selected.Id}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã xóa/ngưng dịch vụ POI.", Severity.Success);
            _selected = null;
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Không thể xóa/ngưng dịch vụ POI.", Severity.Error);
    }

    private static List<string> ParseTags(string value)
    {
        return (value ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Take(8)
            .ToList();
    }

    private static Color StatusColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "Submitted" => Color.Warning,
        _ => Color.Default,
    };

    public ValueTask DisposeAsync()
    {
        _translationDebounceCts?.Cancel();
        _translationDebounceCts?.Dispose();
        _mapRef?.Dispose();
        return ValueTask.CompletedTask;
    }

