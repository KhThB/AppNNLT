@page "/admin/poi-management"
@rendermode InteractiveServer
@using TourGuide.WebAdmin.Components.Shared
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject IConfiguration Config
@inject ISnackbar Snackbar

<PortalGuard RequiredRole="Admin" RedirectTo="/admin/login" OnAuthorized="LoadAfterAuthAsync">
    <MudText Typo="Typo.h4" Class="mb-4">Quản lý POI</MudText>

    <MudGrid Class="mb-4">
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="_search" Label="Search" Variant="Variant.Outlined" Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_status" Label="Status" Variant="Variant.Outlined">
                <MudSelectItem Value="@string.Empty">Tất cả</MudSelectItem>
                <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                <MudSelectItem Value="@("Submitted")">Submitted</MudSelectItem>
                <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
                <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadAsync">Lọc</MudButton>
        </MudItem>
    </MudGrid>

    <MudTable Items="_items" Hover="true" Dense="true" Loading="_loading">
        <HeaderContent>
            <MudTh>Tên quán</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh>Gói</MudTh>
            <MudTh>QR/TTS</MudTh>
            <MudTh>Hành động</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
            <MudTd>@context.SubscriptionPackage</MudTd>
            <MudTd>@context.CountedQrScanCount / @context.CountedTtsPlayCount</MudTd>
            <MudTd>
                <div class="d-flex gap-2">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" OnClick="() => SelectPoi(context)">Sửa</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Href="@GetQrUrl(context.Id)" Target="_blank">WebQR</MudButton>
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPagination Count="@Math.Max(1, _totalPages)" Selected="_page" SelectedChanged="OnPageChanged" Class="mt-4" />

    @if (_selected != null)
    {
        <MudPaper Class="pa-6 mt-6 glass-panel" Style="border-radius: 16px;">
            <MudText Typo="Typo.h6" Class="mb-4">Chỉnh sửa POI</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_selected.Name" Label="Tên quán" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_selected.Address" Label="Địa chỉ" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_selected.SourceDescription" Label="Nội dung nguồn" Variant="Variant.Outlined" Lines="6" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="double" @bind-Value="_selected.Latitude" Label="Latitude" Variant="Variant.Outlined" Class="mb-4" />
                    <MudNumericField T="double" @bind-Value="_selected.Longitude" Label="Longitude" Variant="Variant.Outlined" Class="mb-4" />
                    <MudSlider @bind-Value="_selected.Radius" Min="10" Max="500" Step="10" Color="Color.Primary" Class="mb-4">Radius: @_selected.Radius m</MudSlider>
                    <MudNumericField T="int" @bind-Value="_selected.PriorityLevel" Label="Priority" Variant="Variant.Outlined" Class="mb-4" />
                    <MudNumericField T="int" @bind-Value="_selected.BoostPriority" Label="Boost Priority" Variant="Variant.Outlined" Class="mb-4" />
                </MudItem>
            </MudGrid>

            <div class="d-flex gap-3 mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSelectedAsync">Lưu</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="SubmitSelectedAsync">Submit lại</MudButton>
            </div>
        </MudPaper>
    }
</PortalGuard>

@code {
    private List<PoiItem> _items = new();
    private PoiItem? _selected;
    private bool _loading = true;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private int _page = 1;
    private int _totalPages = 1;

    private async Task OnPageChanged(int newPage)
    {
        _page = newPage;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<PagedResponse>($"api/poi?search={Uri.EscapeDataString(_search)}&status={Uri.EscapeDataString(_status)}&page={_page}&pageSize=12");
            _items = result?.Items ?? new();
            _totalPages = result?.TotalPages ?? 1;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POIs: {ex}");
            Snackbar.Add("Lỗi tải dữ liệu POI. Vui lòng kiểm tra lại kết nối.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadAfterAuthAsync(SessionUser user)
    {
        await ReloadAsync();
        StateHasChanged();
    }

    private void SelectPoi(PoiItem item)
    {
        _selected = new PoiItem
        {
            Id = item.Id,
            Name = item.Name,
            Address = item.Address,
            SourceDescription = item.SourceDescription,
            Latitude = item.Latitude,
            Longitude = item.Longitude,
            Radius = item.Radius,
            PriorityLevel = item.PriorityLevel,
            BoostPriority = item.BoostPriority,
            SubscriptionPackage = item.SubscriptionPackage,
            ImageUrl = item.ImageUrl,
        };
    }

    private async Task SaveSelectedAsync()
    {
        if (_selected == null) return;

        var response = await Http.PutAsJsonAsync($"api/poi/{_selected.Id}", new
        {
            _selected.Name,
            _selected.Address,
            SourceLanguage = "vi",
            SourceDescription = _selected.SourceDescription,
            MerchantNote = _selected.SourceDescription,
            _selected.Latitude,
            _selected.Longitude,
            _selected.Radius,
            _selected.PriorityLevel,
            _selected.BoostPriority,
            _selected.SubscriptionPackage,
            _selected.ImageUrl,
        });

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã lưu POI.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Lưu POI thất bại.", Severity.Error);
    }

    private async Task SubmitSelectedAsync()
    {
        if (_selected == null) return;
        var response = await Http.PostAsync($"api/poi/{_selected.Id}/submit", null);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã submit lại POI.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Submit POI thất bại.", Severity.Error);
    }

    private string GetQrUrl(string id) => $"{Config["FrontendUrls:WebQrBaseUrl"]}/poi/{id}";

    private sealed class PagedResponse
    {
        public List<PoiItem> Items { get; set; } = new();
        public int TotalPages { get; set; }
    }

    private sealed class PoiItem
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string SubscriptionPackage { get; set; } = string.Empty;
        public int CountedQrScanCount { get; set; }
        public int CountedTtsPlayCount { get; set; }
        public string SourceDescription { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double Radius { get; set; }
        public int PriorityLevel { get; set; }
        public int BoostPriority { get; set; }
        public string ImageUrl { get; set; } = string.Empty;
    }
}
