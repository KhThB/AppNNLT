@page "/admin/poi-management"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.JSInterop
@using TourGuide.WebAdmin.Components.Shared
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject IConfiguration Config
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PortalGuard RequiredRole="Admin" RedirectTo="/admin/login" OnAuthorized="LoadAfterAuthAsync">
    <MudText Typo="Typo.h4" Class="mb-2">Quản lý POI tổng</MudText>
    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
        Tổng số quán theo bộ lọc hiện tại: @_totalItems
    </MudAlert>

    <MudGrid Class="mb-4">
        <MudItem xs="12" md="5">
            <MudTextField @bind-Value="_search" Label="Tìm kiếm" Variant="Variant.Outlined" Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" @bind-Value="_status" Label="Trạng thái" Variant="Variant.Outlined">
                <MudSelectItem Value="@string.Empty">Tất cả</MudSelectItem>
                <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                <MudSelectItem Value="@("Submitted")">Submitted</MudSelectItem>
                <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
                <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
                <MudSelectItem Value="@("Archived")">Archived</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="2">
            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadAsync">Lọc</MudButton>
        </MudItem>
    </MudGrid>

    <MudTable Items="_items" Hover="true" Dense="true" Loading="_loading">
        <HeaderContent>
            <MudTh>Tên quán</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh>Gói</MudTh>
            <MudTh>QR/TTS</MudTh>
            <MudTh>Hành động</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
            <MudTd>@context.SubscriptionPackage</MudTd>
            <MudTd>@context.CountedQrScanCount / @context.CountedTtsPlayCount</MudTd>
            <MudTd>
                <div class="d-flex gap-2">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" OnClick="() => SelectPoi(context)">Sửa</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary" Href="@GetQrUrl(context.Id)" Target="_blank">WebQR</MudButton>
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPagination Count="@Math.Max(1, _totalPages)" Selected="_page" SelectedChanged="OnPageChanged" Class="mt-4" />

    @if (_selected != null)
    {
        <MudPaper Class="pa-6 mt-6 glass-panel" Style="border-radius: 16px;">
            <MudText Typo="Typo.h6" Class="mb-4">Chỉnh sửa POI</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_selected.Name" Label="Tên quán" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_selected.Address" Label="Địa chỉ" Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField T="string" Value="_selected.SourceDescription" ValueChanged="OnSelectedSourceDescriptionChangedAsync" Label="Nội dung nguồn" Variant="Variant.Outlined" Lines="6" Immediate="true" />
                    <MudPaper Class="pa-3 my-4" Outlined="true">
                        <div class="d-flex justify-space-between align-center mb-2">
                            <div>
                                <MudText Typo="Typo.subtitle2">Bản dịch sẽ lưu cùng POI</MudText>
                                <MudText Typo="Typo.caption">Admin có thể dịch lại từ nội dung nguồn hoặc chỉnh tay từng ngôn ngữ.</MudText>
                            </div>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Disabled="_translationLoading" OnClick="() => PreviewSelectedTranslationsAsync(true)">
                                Dịch ngay
                            </MudButton>
                        </div>
                        @if (_translationLoading)
                        {
                            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                        }
                        @if (!string.IsNullOrWhiteSpace(_translationMessage))
                        {
                            <MudAlert Severity="@GetTranslationAlertSeverity(_selected)" Dense="true" Class="mb-3">
                                @_translationMessage
                            </MudAlert>
                        }
                        @foreach (var language in TranslationLanguages)
                        {
                            var code = language.Code;
                            <MudTextField T="string"
                                          Value="@GetTranslation(_selected, code)"
                                          ValueChanged="@(value => SetTranslation(_selected, code, value))"
                                          Label="@($"{language.Label} ({code})")"
                                          HelperText="@GetTranslationHelper(_selected, code)"
                                          Variant="Variant.Outlined"
                                          Lines="3"
                                          Class="mb-3" />
                        }
                    </MudPaper>
                    <MudNumericField T="int" @bind-Value="_selected.PriorityLevel" Label="Priority" Variant="Variant.Outlined" Class="mb-4" />
                    <MudNumericField T="int" @bind-Value="_selected.BoostPriority" Label="Boost Priority" Variant="Variant.Outlined" Class="mb-4" />
                    <MudSelect T="string" Value="_selected.SubscriptionPackage" ValueChanged="OnPackageChangedAsync" Label="Gói dịch vụ" Variant="Variant.Outlined" Class="mb-4">
                        <MudSelectItem Value="@("Basic")">Basic - mặc định 50m</MudSelectItem>
                        <MudSelectItem Value="@("Premium")">Premium - mặc định 120m</MudSelectItem>
                        <MudSelectItem Value="@("Boost")">Boost - mặc định 200m</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Vị trí và vùng ảnh hưởng</MudText>
                    <div id="@LocationMapId" style="height: 330px; width: 100%; border-radius: 12px; border: 1px solid #cbd5e1;"></div>
                    <MudText Typo="Typo.caption" Class="mt-2 d-block">
                        Kéo marker hoặc click lên bản đồ để đổi vị trí. Vòng tròn là radius geofence của POI.
                    </MudText>
                    <MudGrid Class="mt-3">
                        <MudItem xs="12" sm="6">
                            <MudNumericField T="double" Value="_selected.Latitude" ValueChanged="OnLatitudeChangedAsync" Label="Latitude" Variant="Variant.Outlined" Class="mb-3" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField T="double" Value="_selected.Longitude" ValueChanged="OnLongitudeChangedAsync" Label="Longitude" Variant="Variant.Outlined" Class="mb-3" />
                        </MudItem>
                    </MudGrid>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                        Radius hiện tại: @_selected.Radius.ToString("N0") m. Hệ thống tự áp dụng theo gói, không chỉnh tay.
                    </MudAlert>
                </MudItem>
            </MudGrid>

            <div class="d-flex gap-3 mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSelectedAsync">Lưu</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="SubmitSelectedAsync">Submit lại</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ArchiveSelectedAsync">Xóa / ngưng dịch vụ</MudButton>
            </div>
        </MudPaper>
    }
</PortalGuard>

@code {
    private const string LocationMapId = "admin-poi-location-map";
    private List<PoiItem> _items = new();
    private PoiItem? _selected;
    private bool _loading = true;
    private bool _locationMapPending;
    private bool _translationLoading;
    private string _translationMessage = string.Empty;
    private CancellationTokenSource? _translationDebounceCts;
    private string _search = string.Empty;
    private string _status = string.Empty;
    private int _page = 1;
    private int _totalPages = 1;
    private long _totalItems;
    private DotNetObjectReference<POIManagement>? _mapRef;
    private static readonly TranslationLanguage[] TranslationLanguages =
    [
        new("EN", "English"),
        new("KO", "Korean"),
        new("JA", "Japanese"),
        new("ZH", "Chinese"),
    ];

    private async Task OnPageChanged(int newPage)
    {
        _page = newPage;
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<PagedResponse>($"api/poi?search={Uri.EscapeDataString(_search)}&status={Uri.EscapeDataString(_status)}&page={_page}&pageSize=12");
            _items = result?.Items ?? new();
            _totalPages = result?.TotalPages ?? 1;
            _totalItems = result?.TotalItems ?? _items.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POIs: {ex}");
            Snackbar.Add("Lỗi tải dữ liệu POI. Vui lòng kiểm tra lại kết nối.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadAfterAuthAsync(SessionUser user)
    {
        await ReloadAsync();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_locationMapPending && _selected != null)
        {
            _locationMapPending = false;
            _mapRef?.Dispose();
            _mapRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initPoiLocationEditor", LocationMapId, _selected.Latitude, _selected.Longitude, _selected.Radius, _mapRef);
        }
    }

    private void SelectPoi(PoiItem item)
    {
        _selected = new PoiItem
        {
            Id = item.Id,
            Name = item.Name,
            Address = item.Address,
            SourceDescription = item.SourceDescription,
            TranslatedDescriptions = new Dictionary<string, string>(item.TranslatedDescriptions, StringComparer.OrdinalIgnoreCase),
            TranslationStatuses = BuildReadyStatuses(item.TranslatedDescriptions),
            Latitude = item.Latitude,
            Longitude = item.Longitude,
            Radius = item.Radius <= 0 ? DefaultRadius(item.SubscriptionPackage) : item.Radius,
            PriorityLevel = item.PriorityLevel,
            BoostPriority = item.BoostPriority,
            SubscriptionPackage = item.SubscriptionPackage,
            ImageUrl = item.ImageUrl,
        };
        _translationMessage = _selected.TranslatedDescriptions.Count > 0
            ? "Đã tải bản dịch hiện có. Sửa nội dung nguồn sẽ tự dịch lại."
            : "Chưa có bản dịch. Nhập nội dung nguồn hoặc bấm Dịch ngay.";
        _locationMapPending = true;
    }

    [JSInvokable]
    public void UpdateLocationFromMap(double latitude, double longitude)
    {
        if (_selected == null)
        {
            return;
        }

        _selected.Latitude = Math.Round(latitude, 6);
        _selected.Longitude = Math.Round(longitude, 6);
        StateHasChanged();
    }

    private async Task OnLatitudeChangedAsync(double value)
    {
        if (_selected == null) return;
        _selected.Latitude = value;
        await JS.InvokeVoidAsync("updatePoiLocationPosition", LocationMapId, _selected.Latitude, _selected.Longitude);
    }

    private async Task OnLongitudeChangedAsync(double value)
    {
        if (_selected == null) return;
        _selected.Longitude = value;
        await JS.InvokeVoidAsync("updatePoiLocationPosition", LocationMapId, _selected.Latitude, _selected.Longitude);
    }

    private async Task OnPackageChangedAsync(string packageName)
    {
        if (_selected == null)
        {
            return;
        }

        _selected.SubscriptionPackage = packageName;
        _selected.Radius = DefaultRadius(packageName);
        await JS.InvokeVoidAsync("updatePoiLocationRadius", LocationMapId, _selected.Radius);
    }

    private async Task SaveSelectedAsync()
    {
        if (_selected == null) return;
        if (!HasReadyTranslations(_selected))
        {
            await PreviewSelectedTranslationsAsync(false);
        }

        var response = await Http.PutAsJsonAsync($"api/poi/{_selected.Id}", new
        {
            _selected.Name,
            _selected.Address,
            SourceLanguage = "vi",
            SourceDescription = _selected.SourceDescription,
            TranslatedDescriptions = BuildReadyTranslations(_selected),
            MerchantNote = _selected.SourceDescription,
            _selected.Latitude,
            _selected.Longitude,
            _selected.PriorityLevel,
            _selected.BoostPriority,
            _selected.SubscriptionPackage,
            _selected.ImageUrl,
        });

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã lưu POI.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Lưu POI thất bại.", Severity.Error);
    }

    private Task OnSelectedSourceDescriptionChangedAsync(string value)
    {
        if (_selected == null)
        {
            return Task.CompletedTask;
        }

        _selected.SourceDescription = value;
        QueueTranslationPreview();
        return Task.CompletedTask;
    }

    private void QueueTranslationPreview()
    {
        _translationDebounceCts?.Cancel();
        _translationDebounceCts?.Dispose();

        if (_selected == null || string.IsNullOrWhiteSpace(_selected.SourceDescription))
        {
            if (_selected != null)
            {
                _selected.TranslatedDescriptions.Clear();
                _selected.TranslationStatuses.Clear();
                _selected.TranslationErrors.Clear();
            }

            _translationMessage = string.Empty;
            return;
        }

        foreach (var language in TranslationLanguages)
        {
            _selected.TranslatedDescriptions[language.Code] = string.Empty;
            _selected.TranslationStatuses[language.Code] = "PendingManual";
            _selected.TranslationErrors.Remove(language.Code);
        }

        var cts = new CancellationTokenSource();
        _translationDebounceCts = cts;
        _ = DebouncedPreviewAsync(cts.Token);
    }

    private async Task DebouncedPreviewAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(900, cancellationToken);
            await InvokeAsync(() => PreviewSelectedTranslationsAsync(false));
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task PreviewSelectedTranslationsAsync(bool showSnackbar)
    {
        if (_selected == null)
        {
            return;
        }

        var sourceText = (_selected.SourceDescription ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(sourceText))
        {
            _selected.TranslatedDescriptions.Clear();
            _selected.TranslationStatuses.Clear();
            _selected.TranslationErrors.Clear();
            _translationMessage = string.Empty;
            return;
        }

        _translationLoading = true;
        _translationMessage = "Đang dịch nội dung nguồn...";
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/translation/preview", new TranslationPreviewRequestModel
            {
                SourceLanguage = "vi",
                SourceDescription = sourceText,
                TargetLanguages = TranslationLanguages.Select(x => x.Code).ToArray(),
            });

            if (!response.IsSuccessStatusCode)
            {
                _translationMessage = "Không gọi được API dịch. Bạn vẫn có thể nhập bản dịch thủ công.";
                if (showSnackbar)
                {
                    Snackbar.Add(_translationMessage, Severity.Warning);
                }

                return;
            }

            var preview = await response.Content.ReadFromJsonAsync<TranslationPreviewResponseModel>();
            if (preview == null)
            {
                _translationMessage = "API dịch không trả về dữ liệu hợp lệ.";
                return;
            }

            foreach (var language in TranslationLanguages)
            {
                if (!preview.Contents.TryGetValue(language.Code, out var content))
                {
                    continue;
                }

                _selected.TranslationStatuses[language.Code] = content.Status;
                _selected.TranslationErrors[language.Code] = content.ErrorMessage;
                if (content.Status == "Ready")
                {
                    _selected.TranslatedDescriptions[language.Code] = content.Description;
                }
                else if (!_selected.TranslatedDescriptions.ContainsKey(language.Code))
                {
                    _selected.TranslatedDescriptions[language.Code] = string.Empty;
                }
            }

            _translationMessage = preview.IsProviderConfigured
                ? "Bản dịch đã sẵn sàng và sẽ được lưu cùng POI."
                : "Google Cloud Translation chưa được cấu hình. Nhập tay bản dịch hoặc cấu hình API key.";

            if (showSnackbar)
            {
                Snackbar.Add(_translationMessage, preview.IsProviderConfigured ? Severity.Success : Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            _translationMessage = $"Lỗi dịch: {ex.Message}";
            if (showSnackbar)
            {
                Snackbar.Add(_translationMessage, Severity.Error);
            }
        }
        finally
        {
            _translationLoading = false;
            StateHasChanged();
        }
    }

    private static string GetTranslation(PoiItem? model, string language)
    {
        return model?.TranslatedDescriptions.TryGetValue(language, out var text) == true ? text : string.Empty;
    }

    private static void SetTranslation(PoiItem? model, string language, string value)
    {
        if (model == null)
        {
            return;
        }

        model.TranslatedDescriptions[language] = value;
        model.TranslationStatuses[language] = string.IsNullOrWhiteSpace(value) ? "PendingManual" : "Ready";
        model.TranslationErrors.Remove(language);
    }

    private static string GetTranslationHelper(PoiItem? model, string language)
    {
        if (model == null)
        {
            return string.Empty;
        }

        var status = model.TranslationStatuses.TryGetValue(language, out var value) ? value : "PendingManual";
        if (status == "Ready")
        {
            return "Sẵn sàng lưu xuống DB.";
        }

        return model.TranslationErrors.TryGetValue(language, out var error) && !string.IsNullOrWhiteSpace(error)
            ? error
            : "Chưa có bản dịch. Có thể nhập tay.";
    }

    private static Dictionary<string, string> BuildReadyTranslations(PoiItem model)
    {
        return TranslationLanguages
            .Where(x => model.TranslationStatuses.TryGetValue(x.Code, out var status) && status == "Ready")
            .Select(x => new { x.Code, Text = GetTranslation(model, x.Code).Trim() })
            .Where(x => !string.IsNullOrWhiteSpace(x.Text))
            .ToDictionary(x => x.Code, x => x.Text, StringComparer.OrdinalIgnoreCase);
    }

    private static bool HasReadyTranslations(PoiItem model)
    {
        return BuildReadyTranslations(model).Count > 0;
    }

    private static Severity GetTranslationAlertSeverity(PoiItem model)
    {
        return model.TranslationStatuses.Values.Any(x => x == "PendingManual")
            ? Severity.Warning
            : Severity.Success;
    }

    private static Dictionary<string, string> BuildReadyStatuses(IReadOnlyDictionary<string, string> translations)
    {
        return translations
            .Where(x => !string.IsNullOrWhiteSpace(x.Value))
            .ToDictionary(x => x.Key, _ => "Ready", StringComparer.OrdinalIgnoreCase);
    }

    private async Task SubmitSelectedAsync()
    {
        if (_selected == null) return;
        var response = await Http.PostAsync($"api/poi/{_selected.Id}/submit", null);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã submit lại POI.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Submit POI thất bại.", Severity.Error);
    }

    private async Task ArchiveSelectedAsync()
    {
        if (_selected == null) return;
        var response = await Http.DeleteAsync($"api/poi/{_selected.Id}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã xóa/ngưng dịch vụ POI.", Severity.Success);
            _selected = null;
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Không thể xóa/ngưng dịch vụ POI.", Severity.Error);
    }

    private string GetQrUrl(string id) => $"{Config["FrontendUrls:WebQrBaseUrl"]}/poi/{id}";

    private static double DefaultRadius(string packageName) => packageName switch
    {
        "Premium" => 120,
        "Boost" => 200,
        _ => 50,
    };

    public ValueTask DisposeAsync()
    {
        _translationDebounceCts?.Cancel();
        _translationDebounceCts?.Dispose();
        _mapRef?.Dispose();
        return ValueTask.CompletedTask;
    }

    private sealed record TranslationLanguage(string Code, string Label);

    private sealed class PagedResponse
    {
        public List<PoiItem> Items { get; set; } = new();
        public int TotalPages { get; set; }
        public long TotalItems { get; set; }
    }

    private sealed class PoiItem
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string SubscriptionPackage { get; set; } = string.Empty;
        public int CountedQrScanCount { get; set; }
        public int CountedTtsPlayCount { get; set; }
        public string SourceDescription { get; set; } = string.Empty;
        public Dictionary<string, string> TranslatedDescriptions { get; set; } = new(StringComparer.OrdinalIgnoreCase);
        public Dictionary<string, string> TranslationStatuses { get; set; } = new(StringComparer.OrdinalIgnoreCase);
        public Dictionary<string, string> TranslationErrors { get; set; } = new(StringComparer.OrdinalIgnoreCase);
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double Radius { get; set; }
        public int PriorityLevel { get; set; }
        public int BoostPriority { get; set; }
        public string ImageUrl { get; set; } = string.Empty;
    }
}
