@page "/poi-approval"
@rendermode InteractiveServer
@using TourGuide.Domain.Models
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject MudBlazor.ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Phê Duyệt Quán Ăn</MudText>

<MudTable Items="@pendingPOIs" Hover="true" Striped="true" Loading="@(pendingPOIs == null)">
    <HeaderContent>
        <MudTh>Tên Quán</MudTh>
        <MudTh Style="width: 100px;">Ảnh</MudTh>
        <MudTh>Mức Ưu Tiên</MudTh>
        <MudTh>Hành Động</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Tên Quán">@context.Name</MudTd>
        <MudTd DataLabel="Ảnh">
            @if (!string.IsNullOrEmpty(context.ImageUrl))
            {
                @* Dùng Http.BaseAddress để tự động lấy tên miền của API *@
                <img src="@($"{Http.BaseAddress?.ToString().TrimEnd('/')}{context.ImageUrl}")"
                     style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Error">Chưa có ảnh</MudText>
            }
        </MudTd>
        <MudTd DataLabel="Mức Ưu Tiên">@context.PriorityLevel</MudTd>
        <MudTd DataLabel="Hành Động">
            <div class="d-flex align-center gap-2">
                <InputFile id="@($"fileInput-{context.Id}")"
                           OnChange="@(e => UploadImage(e, context))"
                           hidden accept=".jpg,.jpeg,.png" />
                
                <MudButton HtmlTag="label"
                           for="@($"fileInput-{context.Id}")"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Image">Up Ảnh</MudButton>

                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="@(() => UpdateStatus(context.Id, "approve"))">Duyệt</MudButton>
            </div>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<POI>? pendingPOIs;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() =>
        pendingPOIs = await Http.GetFromJsonAsync<List<POI>>("api/POI/pending");

    private async Task UpdateStatus(string id, string action)
    {
        await Http.PutAsync($"api/POI/{id}/{action}", null);
        await LoadData();
    }

    private async Task UploadImage(InputFileChangeEventArgs e, POI poi)
    {
        var file = e.File;
        if (file == null) return;
        
        long maxFileSize = 1024 * 1024 * 5;

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxFileSize);
            using var streamContent = new StreamContent(stream);

            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(streamContent, "file", file.Name);
            
            // Xóa Localhost, chỉ dùng đường dẫn tương đối
            var response = await Http.PostAsync("api/POI/upload-image", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                if (result != null && !string.IsNullOrEmpty(result.ImageUrl))
                {
                    poi.ImageUrl = result.ImageUrl;
                    await Http.PutAsJsonAsync($"api/POI/{poi.Id}", poi);
                    
                    Snackbar.Add("Tải ảnh lên thành công!", Severity.Success);
                    await LoadData();
                }
            }
            else
            {
                Snackbar.Add("API từ chối nhận file.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private class UploadResult
    {
        public string ImageUrl { get; set; } = "";
    }
}