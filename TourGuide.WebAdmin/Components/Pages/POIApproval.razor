@page "/admin/poi-approval"
@rendermode InteractiveServer
@using TourGuide.WebAdmin.Components.Shared
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject ISnackbar Snackbar

<PortalGuard RequiredRole="Admin" RedirectTo="/admin/login" OnAuthorized="LoadAfterAuthAsync">
    <MudText Typo="Typo.h4" Class="mb-4">POI chờ duyệt</MudText>

    <MudTable Items="_items" Hover="true" Striped="true" Loading="_loading">
        <HeaderContent>
            <MudTh>Tên quán</MudTh>
            <MudTh>Trạng thái moderation</MudTh>
            <MudTh>Nội dung nguồn</MudTh>
            <MudTh>Reject reason</MudTh>
            <MudTh>Hành động</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>
                <MudChip T="string" Color="@ChipColor(context.ModerationStatus)" Size="Size.Small">@context.ModerationStatus</MudChip>
            </MudTd>
            <MudTd>@Shorten(context.SourceDescription)</MudTd>
            <MudTd>
                <MudTextField T="string" Value="@GetReason(context.Id)" ValueChanged="value => SetReason(context.Id, value)" Variant="Variant.Outlined" />
            </MudTd>
            <MudTd>
                <div class="d-flex gap-2">
                    <MudButton Size="Size.Small" Color="Color.Success" Variant="Variant.Filled" OnClick="() => ReviewAsync(context.Id, true)">Duyệt</MudButton>
                    <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined" OnClick="() => ReviewAsync(context.Id, false)">Từ chối</MudButton>
                </div>
            </MudTd>
        </RowTemplate>
    </MudTable>
</PortalGuard>

@code {
    private List<PoiItem> _items = new();
    private Dictionary<string, string> _reasons = new();
    private bool _loading = true;

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<PagedResponse>("api/poi?status=Submitted&page=1&pageSize=50");
            _items = result?.Items ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading POI Approvals: {ex}");
            Snackbar.Add("Lỗi tải dữ liệu POI chờ duyệt. Vui lòng kiểm tra lại kết nối.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadAfterAuthAsync(SessionUser user)
    {
        await ReloadAsync();
        StateHasChanged();
    }

    private string GetReason(string id) => _reasons.TryGetValue(id, out var reason) ? reason : string.Empty;
    private void SetReason(string id, string value) => _reasons[id] = value;

    private async Task ReviewAsync(string id, bool approve)
    {
        var response = await Http.PostAsJsonAsync($"api/poi/{id}/review", new
        {
            Approve = approve,
            RejectionReason = GetReason(id),
        });

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(approve ? "Đã duyệt POI." : "Đã từ chối POI.", Severity.Success);
            await ReloadAsync();
            return;
        }

        Snackbar.Add("Không thể cập nhật trạng thái duyệt.", Severity.Error);
    }

    private static string Shorten(string text) => string.IsNullOrWhiteSpace(text) || text.Length <= 90 ? text : $"{text[..90]}...";

    private static Color ChipColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Warning,
    };

    private sealed class PagedResponse
    {
        public List<PoiItem> Items { get; set; } = new();
    }

    private sealed class PoiItem
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ModerationStatus { get; set; } = string.Empty;
        public string SourceDescription { get; set; } = string.Empty;
    }
}
