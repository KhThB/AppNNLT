@using System.Net.Http.Headers
@using Blazored.LocalStorage
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <span class="portal-logo portal-logo-admin">A</span>
            <span>TourGuide Admin</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler')?.click()">
    <nav class="flex-column">
        @if (!_ready)
        {
            <div class="portal-role-chip mx-3 mb-3">
                <span class="portal-logo portal-logo-admin">A</span>
                <span>Đang kiểm tra</span>
            </div>
        }
        else if (_hasToken)
        {
            <div class="portal-role-chip mx-3 mb-3">
                <span class="portal-logo portal-logo-admin">A</span>
                <span>Chế độ Admin</span>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/dashboard" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard thống kê
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/poi-approval">
                    <span class="bi bi-check-circle-fill" aria-hidden="true"></span> Duyệt POI
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/poi-management">
                    <span class="bi bi-qr-code-scan" aria-hidden="true"></span> Quản lý POI tổng
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-button" @onclick="LogoutAsync">
                    <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Đăng xuất
                </button>
            </div>
        }
        else
        {
            <div class="portal-role-chip mx-3 mb-3">
                <span class="portal-logo portal-logo-admin">A</span>
                <span>Cổng Admin</span>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/login">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Đăng nhập
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool _ready;
    private bool _hasToken;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RefreshAuthStateAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task RefreshAuthStateAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            _hasToken = false;
            return;
        }

        try
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var me = await Http.GetFromJsonAsync<SessionUser>("api/auth/me");
            _hasToken = string.Equals(me?.Role, "Admin", StringComparison.OrdinalIgnoreCase);

            if (!_hasToken)
            {
                await ClearLocalSessionAsync();
                return;
            }

            await LocalStorage.SetItemAsync("userId", me!.Id);
            await LocalStorage.SetItemAsync("userRole", me.Role);
            await LocalStorage.SetItemAsync("userName", me.FullName);
        }
        catch
        {
            _hasToken = false;
            await ClearLocalSessionAsync();
        }
    }

    private async Task LogoutAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        if (!string.IsNullOrWhiteSpace(token))
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            try
            {
                await Http.PostAsync("api/auth/logout", null);
            }
            catch
            {
            }
        }

        await ClearLocalSessionAsync();
        _hasToken = false;
        Navigation.NavigateTo("/admin/login", true);
    }

    private async Task ClearLocalSessionAsync()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        await LocalStorage.RemoveItemAsync("userId");
        await LocalStorage.RemoveItemAsync("userRole");
        await LocalStorage.RemoveItemAsync("userName");
    }
}
