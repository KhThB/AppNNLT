@inherits LayoutComponentBase
@using Blazored.LocalStorage
@using System.Net.Http.Headers
@using MudBlazor
@using TourGuide.WebAdmin.Helpers
@using TourGuide.WebAdmin.Models
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<MudThemeProvider Theme="CustomTheme.MerchantTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />
<MudLayout>
    <MudAppBar Color="Color.Primary" Fixed="true" Elevation="2">
        <span class="portal-logo portal-logo-merchant mr-3">M</span>
        <MudText Typo="Typo.h5" Style="font-weight: 700;">VinhKhanh FoodTour <span style="font-weight: 300; opacity: 0.82">| Merchant</span></MudText>
        <MudSpacer />
        @if (!_ready)
        {
            <span class="portal-role-chip portal-role-chip-light">
                <span class="portal-logo portal-logo-merchant">M</span>
                <span>Đang kiểm tra</span>
            </span>
        }
        else if (_hasToken)
        {
            <div class="merchant-nav-actions">
                <span class="portal-role-chip portal-role-chip-light">
                    <span class="portal-logo portal-logo-merchant">M</span>
                    <span>Merchant</span>
                </span>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="/merchant/dashboard" StartIcon="@Icons.Material.Filled.Dashboard">Dashboard</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="/merchant/register" StartIcon="@Icons.Material.Filled.AddLocationAlt">Tạo POI</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="/merchant/pois" StartIcon="@Icons.Material.Filled.Storefront">Quản lý POI</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="/merchant/billing" StartIcon="@Icons.Material.Filled.ReceiptLong">Gói & hóa đơn</MudButton>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" OnClick="LogoutAsync" StartIcon="@Icons.Material.Filled.Logout">Đăng xuất</MudButton>
            </div>
        }
        else
        {
            <div class="merchant-nav-actions">
                <span class="portal-role-chip portal-role-chip-light">
                    <span class="portal-logo portal-logo-merchant">M</span>
                    <span>Cổng Merchant</span>
                </span>
                <MudButton Color="Color.Inherit" Variant="Variant.Text" Href="/merchant/login" StartIcon="@Icons.Material.Filled.Login">Đăng nhập</MudButton>
            </div>
        }
    </MudAppBar>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _ready;
    private bool _hasToken;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RefreshAuthStateAsync();
        _ready = true;
        StateHasChanged();
    }

    private async Task RefreshAuthStateAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            _hasToken = false;
            return;
        }

        try
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var me = await Http.GetFromJsonAsync<SessionUser>("api/auth/me");
            _hasToken = string.Equals(me?.Role, "Merchant", StringComparison.OrdinalIgnoreCase);

            if (!_hasToken)
            {
                await ClearLocalSessionAsync();
                return;
            }

            await LocalStorage.SetItemAsync("userId", me!.Id);
            await LocalStorage.SetItemAsync("userRole", me.Role);
            await LocalStorage.SetItemAsync("userName", me.FullName);
        }
        catch
        {
            _hasToken = false;
            await ClearLocalSessionAsync();
        }
    }

    private async Task LogoutAsync()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        if (!string.IsNullOrWhiteSpace(token))
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            try
            {
                await Http.PostAsync("api/auth/logout", null);
            }
            catch
            {
            }
        }

        await ClearLocalSessionAsync();
        _hasToken = false;
        Navigation.NavigateTo("/merchant/login", true);
    }

    private async Task ClearLocalSessionAsync()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        await LocalStorage.RemoveItemAsync("userId");
        await LocalStorage.RemoveItemAsync("userRole");
        await LocalStorage.RemoveItemAsync("userName");
    }
}
