@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Primary" Fixed="true">
        <MudIcon Icon="@Icons.Material.Filled.Restaurant" Class="mr-2" />
        <MudText Typo="Typo.h6">VinhKhanh FoodTour - Cổng Chủ Quán</MudText>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>