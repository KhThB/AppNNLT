@page "/poi/{Id}"
@rendermode InteractiveServer
@using TourGuide.Domain.Models
@inject HttpClient Http
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-0" Style="background-color: #f8f9fa; min-height: 100vh;">
    @if (_poi == null)
    {
        <div class="d-flex justify-center align-center" style="height: 100vh;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="ml-3">Đang tải thông tin quán...</MudText>
        </div>
    }
    else
    {
        <div style="width: 100%; height: 250px; background-color: #eee;">
            @if (!string.IsNullOrEmpty(_poi.ImageUrl))
            {
                <img src="@(_poi.ImageUrl.StartsWith("http") ? _poi.ImageUrl : $"{Http.BaseAddress}{_poi.ImageUrl.TrimStart('/')}")" 
                     style="width: 100%; height: 100%; object-fit: cover;" alt="@_poi.Name" />
            }
        </div>

        <div class="pa-6 text-center">
            <MudText Typo="Typo.h4" Style="font-weight: 800; color: #333;" Class="mb-4">@_poi.Name</MudText>

            @if (_poi.Location?.Coordinates != null && _poi.Location.Coordinates.Length == 2)
            {
                var lon = _poi.Location.Coordinates[0].ToString(System.Globalization.CultureInfo.InvariantCulture);
                var lat = _poi.Location.Coordinates[1].ToString(System.Globalization.CultureInfo.InvariantCulture);
                var mapUrl = $"https://www.google.com/maps/dir/?api=1&destination=${lat},{lon}";
                
                <MudButton Href="@mapUrl" Target="_blank" Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.Map" Class="mb-6 w-100" Style="border-radius: 8px;">
                    🗺️ Chỉ đường Map
                </MudButton>
            }

            <MudPaper Elevation="0" Class="pa-5 text-left" Style="background: #f1f3f5; border-radius: 12px; border: 1px solid #e9ecef;">
                
                <MudSelect T="string" Value="@_currentLang" ValueChanged="OnLanguageChanged" Variant="Variant.Outlined" Class="mb-4 text-center" Style="background: white;">
                    <MudSelectItem Value="@("vi-VN")">🇻🇳 Tiếng Việt</MudSelectItem>
                    <MudSelectItem Value="@("en-US")">🇬🇧 Tiếng Anh</MudSelectItem>
                    <MudSelectItem Value="@("ko-KR")">🇰🇷 Tiếng Hàn</MudSelectItem>
                    <MudSelectItem Value="@("ja-JP")">🇯🇵 Tiếng Nhật</MudSelectItem>
                    <MudSelectItem Value="@("zh-CN")">🇨🇳 Tiếng Trung</MudSelectItem>
                </MudSelect>

                <MudText Typo="Typo.body1" Style="color: #555; line-height: 1.6; white-space: pre-wrap;" Class="mb-6">
                    @_displayedText
                </MudText>

                <div class="d-flex gap-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="PlayAudio" Class="flex-grow-1" Style="border-radius: 8px;">
                        ▶ Nghe
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="PauseAudio" Class="flex-grow-1" Style="border-radius: 8px;">
                        ⏸ Tạm dừng
                    </MudButton>
                </div>
            </MudPaper>
        </div>
    }
</MudContainer>
@code {
    [Parameter] public string? Id { get; set; }
    
    private POI? _poi;
    private string _currentLang = "vi-VN";
    private string _displayedText = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _poi = await Http.GetFromJsonAsync<POI>($"api/POI/details/{Id}");
            if (_poi != null)
            {
                UpdateDisplayedText();
                
                // Gọi API Tracking an toàn, không làm sập luồng chính
                await SendTrackingAsync("ScanQR");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
    }

    private void OnLanguageChanged(string newLang)
    {
        _currentLang = newLang;
        UpdateDisplayedText();
        JS.InvokeVoidAsync("tts.stop");
    }

    private void UpdateDisplayedText()
    {
        if (_poi == null) return;
        
        _displayedText = _currentLang switch
        {
            "vi-VN" => string.IsNullOrEmpty(_poi.Description_VI) ? "(Chưa có bài thuyết minh tiếng Việt)" : _poi.Description_VI,
            "en-US" => string.IsNullOrEmpty(_poi.Description_EN) ? "(No English description available)" : _poi.Description_EN,
            "ko-KR" => string.IsNullOrEmpty(_poi.Description_KO) ? "(한국어 설명이 없습니다)" : _poi.Description_KO,
            "ja-JP" => string.IsNullOrEmpty(_poi.Description_JA) ? "(日本語の説明はありません)" : _poi.Description_JA,
            "zh-CN" => string.IsNullOrEmpty(_poi.Description_ZH) ? "(暂无中文说明)" : _poi.Description_ZH,
            _ => _poi.Description_VI
        };
    }

    private async Task PlayAudio()
    {
        if (_displayedText.Contains("(Chưa có") || _displayedText.Contains("(No") || _displayedText.Contains("(暂无")) return;
        
        await JS.InvokeVoidAsync("tts.play", _displayedText, _currentLang);
        await SendTrackingAsync("PlayTTS");
    }

    private async Task PauseAudio()
    {
        await JS.InvokeVoidAsync("tts.pauseResume");
    }

    // Hàm Tracking an toàn: Lỗi cũng không báo ra màn hình làm phiền khách
    private async Task SendTrackingAsync(string actionType)
    {
        try
        {
            await Http.PostAsJsonAsync("api/Tracking", new { PoiId = _poi?.Id, ActionType = actionType });
        }
        catch
        {
            // Âm thầm bỏ qua nếu lỗi mạng
        }
    }
}