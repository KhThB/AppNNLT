@page "/poi/{Id}"
@using System.Text.Json
@using TourGuide.Domain.Models
@inject HttpClient Http

@if (!_loaded)
{
    <div style="min-height:100vh; display:grid; place-items:center;">Đang tải dữ liệu...</div>
}
else if (_poi == null)
{
    <div class="not-found">
        <h2>Không tìm thấy nội dung</h2>
        <p>POI này chưa được duyệt hoặc mã QR không hợp lệ.</p>
    </div>
}
else
{
    var payload = JsonSerializer.Serialize(_poi, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    var apiBase = Http.BaseAddress?.ToString() ?? "/";
    var imageUrl = string.IsNullOrWhiteSpace(_poi.ImageUrl)
        ? "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1200&q=80"
        : _poi.ImageUrl;

    <img src="@imageUrl" class="hero-bg" alt="@_poi.Name" />
    <div class="hero-overlay"></div>

    <div class="glass-panel">
        <div id="qr-banner" class="qr-banner" style="display:none;"></div>
        <h1 class="gradient-text">@_poi.Name</h1>
        <div class="address-text">@_poi.Address</div>

        <div class="lang-selector" id="lang-selector"></div>
        <div class="content-status" id="content-status" style="display:none;"></div>
        <div class="desc-text" id="desc-text"></div>

        <div class="audio-container">
            <div class="play-status" id="play-status" style="display:none;"></div>
            <button id="play-audio-btn" class="hero-action">Nghe thuyết minh</button>
            <button id="stop-audio-btn" class="hero-secondary" style="display:none;">Dừng</button>
        </div>

        <div class="map-section">
            <h3>Vị trí quán ăn</h3>
            <div id="mini-map"></div>
            <button id="directions-btn" class="directions-btn">Chỉ đường đến quán</button>
        </div>
    </div>

    <script>
        window.tourGuideQrPage?.init({
            apiBase: "@apiBase",
            poiId: "@_poi.Id",
            payload: @((MarkupString)payload)
        });
    </script>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    private PoiDetailVm? _poi;
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"api/poi/details/{Id}");
        if (response.IsSuccessStatusCode)
        {
            _poi = await response.Content.ReadFromJsonAsync<PoiDetailVm>();
        }

        _loaded = true;
    }

    private sealed class PoiDetailVm
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public Dictionary<string, PoiLocalizedVm> Contents { get; set; } = new();
    }

    private sealed class PoiLocalizedVm
    {
        public string Description { get; set; } = string.Empty;
        public string AudioUrl { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string ErrorMessage { get; set; } = string.Empty;
    }
}
